# Environment variables for Looker Explore Assistant MCP Server
# Copy this file to .env and update with your actual values

# Google Cloud Configuration
PROJECT=your-gcp-project-id
REGION=us-central1
VERTEX_MODEL=gemini-2.0-flash-001

# Looker Configuration
LOOKER_API_CLIENT_ID=your-looker-client-id
LOOKER_API_CLIENT_SECRET=your-looker-client-secret
LOOKER_BASE_URL=https://your-company.looker.com

# Looker SDK Configuration (usually same as above)
LOOKERSDK_CLIENT_ID=your-looker-client-id
LOOKERSDK_CLIENT_SECRET=your-looker-client-secret

# BigQuery Configuration for Suggested Golden Queries
BQ_PROJECT_ID=ml-accelerator-dbarr
BQ_DATASET_ID=explore_assistant
BQ_SUGGESTED_TABLE=suggested_golden_queries

# Security
MCP_SHARED_SECRET=your-secure-shared-secret

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0

# Note: In Cloud Run deployment, these are set as environment variables
# The deployment script will handle setting these automatically
