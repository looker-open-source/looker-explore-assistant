# Git and version control
.git
.gitignore
*.md
README*
CHANGELOG*
LICENSE*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/
.conda/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
test_files/
tests/
*test*.py

# Development files
.env*
*.local

# Cache directories
cache/
.cache/
__pycache__/

# Development scripts
run_local.sh
restart_server.sh
get_oauth_token.sh
test_*.py
testing/
*copy*/

# Development utilities
scripts/
utils/
nodes/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Deployment scripts (these are for local use)
deploy_to_cloudrun.sh
redeploy*.sh
update_env_vars.sh
fix-cors*.sh

# Frontend files (if accidentally included)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tgz
*.tar.gz

# Exclude other project directories
../explore-assistant-extension/
../explore-assistant-examples/
../explore-assistant-backend/
../explore-assistant-training/
../mcp-wrapper/
../server/
../static/

# Exclude vector MCP (if it's not needed)
explore-assistant-vector-mcp/

# Exclude TypeScript/JavaScript files not needed for Python service
*.ts
*.js
*.json
package*.json
webpack*.js
babel.config.js
postcss.config.js
tailwind.config.js
tsconfig.json

# Exclude documentation files
*.docx
*.pdf
*.png
*.gif
