# Environment variables for local development
# Google Cloud settings
PROJECT=  # Replace with your project ID
REGION=  # Replace with your preferred region
MODEL_NAME="gemini-2.0-flash-lite"  # Or your preferred model
# Looker SDK settings - Uncomment and set these to connect to a real Looker instance
# Note: These are required when not using mock data
LANGSMITH_API_KEY= 
# Set logging to DEBUG for local development
LOG_LEVEL="DEBUG"

# Looker API credentials for MCP server token exchange
LOOKER_API_CLIENT_ID=  # Same as LOOKERSDK_CLIENT_ID
LOOKER_API_CLIENT_SECRET=  # Same as LOOKERSDK_CLIENT_SECRET
LOOKER_BASE_URL="https://xxx.looker.com:19999"  # Same as LOOKERSDK_BASE_URL
LOOKERSDK_CLIENT_ID=  # Replace with your Looker client ID
LOOKERSDK_CLIENT_SECRET=  # Replace with your Looker client secret
LOOKERSDK_VERIFY_SSL="false"  # Set to "true" in production

# IMPORTANT: Make sure the Flask app runs in local mode
# This is critical for local development
FLASK_ENV=development
FLASK_DEBUG=1
